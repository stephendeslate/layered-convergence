generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  PROVIDER
  ADMIN
}

enum TransactionStatus {
  CREATED
  HELD
  RELEASED
  DISPUTED
  RESOLVED_BUYER
  RESOLVED_PROVIDER
  REFUNDED
  EXPIRED
}

enum DisputeStatus {
  OPEN
  EVIDENCE_SUBMITTED
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_PROVIDER
  ESCALATED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OnboardingStatus {
  NOT_STARTED
  PENDING
  COMPLETED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(BUYER)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyerTransactions    Transaction[] @relation("BuyerTransactions")
  providerTransactions Transaction[] @relation("ProviderTransactions")
  disputes             Dispute[]
  connectedAccount     StripeConnectedAccount?
  payouts              Payout[]

  @@index([tenantId])
  @@index([email])
}

model Transaction {
  id            String            @id @default(uuid())
  amount        Int
  currency      String            @default("usd")
  status        TransactionStatus @default(CREATED)
  description   String?
  platformFee   Int               @default(0)
  holdUntil     DateTime?
  stripePaymentIntentId String?   @unique
  tenantId      String

  buyerId    String
  buyer      User   @relation("BuyerTransactions", fields: [buyerId], references: [id])
  providerId String
  provider   User   @relation("ProviderTransactions", fields: [providerId], references: [id])

  stateHistory TransactionStateHistory[]
  disputes     Dispute[]
  payout       Payout?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([buyerId])
  @@index([providerId])
}

model TransactionStateHistory {
  id            String   @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  fromState     TransactionStatus
  toState       TransactionStatus
  reason        String?
  changedBy     String?
  createdAt     DateTime @default(now())

  @@index([transactionId])
}

model Dispute {
  id            String        @id @default(uuid())
  transactionId String
  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  raisedById    String
  raisedBy      User          @relation(fields: [raisedById], references: [id])
  reason        String
  evidence      String?
  status        DisputeStatus @default(OPEN)
  resolution    String?
  tenantId      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
  @@index([tenantId])
}

model StripeConnectedAccount {
  id               String           @id @default(uuid())
  userId           String           @unique
  user             User             @relation(fields: [userId], references: [id])
  stripeAccountId  String           @unique
  onboardingStatus OnboardingStatus @default(NOT_STARTED)
  tenantId         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Payout {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  transactionId    String       @unique
  transaction      Transaction  @relation(fields: [transactionId], references: [id])
  amount           Int
  currency         String       @default("usd")
  stripeTransferId String?
  status           PayoutStatus @default(PENDING)
  tenantId         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tenantId])
}

model WebhookLog {
  id             String   @id @default(uuid())
  provider       String   @default("stripe")
  eventType      String
  payload        Json
  idempotencyKey String   @unique
  processedAt    DateTime?
  tenantId       String?

  createdAt DateTime @default(now())

  @@index([idempotencyKey])
  @@index([eventType])
}
