generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  PROVIDER
  ADMIN
}

enum TransactionStatus {
  CREATED
  HELD
  RELEASED
  DISPUTED
  REFUNDED
  EXPIRED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_PROVIDER
  ESCALATED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(BUYER)
  tenantId  String   @default("default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyerTransactions    Transaction[]         @relation("BuyerTransactions")
  providerTransactions Transaction[]         @relation("ProviderTransactions")
  disputes             Dispute[]
  payouts              Payout[]
  connectedAccount     StripeConnectedAccount?

  @@index([tenantId])
  @@index([email])
}

model Transaction {
  id            String            @id @default(uuid())
  amount        Int
  currency      String            @default("usd")
  status        TransactionStatus @default(CREATED)
  description   String?
  platformFee   Int               @default(0)
  holdUntil     DateTime?
  stripePaymentIntentId String?   @unique
  tenantId      String            @default("default")

  buyerId    String
  buyer      User   @relation("BuyerTransactions", fields: [buyerId], references: [id])
  providerId String
  provider   User   @relation("ProviderTransactions", fields: [providerId], references: [id])

  stateHistory TransactionStateHistory[]
  disputes     Dispute[]
  payouts      Payout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([providerId])
  @@index([status])
  @@index([tenantId])
}

model TransactionStateHistory {
  id            String   @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  fromState     TransactionStatus
  toState       TransactionStatus
  reason        String?
  changedBy     String?
  createdAt     DateTime @default(now())

  @@index([transactionId])
}

model Dispute {
  id            String        @id @default(uuid())
  transactionId String
  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  raisedById    String
  raisedBy      User          @relation(fields: [raisedById], references: [id])
  reason        String
  evidence      String?
  status        DisputeStatus @default(OPEN)
  resolution    String?
  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([transactionId])
  @@index([raisedById])
}

model StripeConnectedAccount {
  id               String           @id @default(uuid())
  userId           String           @unique
  user             User             @relation(fields: [userId], references: [id])
  stripeAccountId  String           @unique
  onboardingStatus OnboardingStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Payout {
  id               String       @id @default(uuid())
  providerId       String
  provider         User         @relation(fields: [providerId], references: [id])
  transactionId    String
  transaction      Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  amount           Int
  stripeTransferId String?      @unique
  status           PayoutStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([providerId])
  @@index([transactionId])
}

model WebhookLog {
  id             String    @id @default(uuid())
  provider       String    @default("stripe")
  eventType      String
  payload        Json
  idempotencyKey String    @unique
  processedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([idempotencyKey])
  @@index([eventType])
}
