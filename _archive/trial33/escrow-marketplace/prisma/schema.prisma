generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BUYER
  PROVIDER
  ADMIN
}

enum TransactionStatus {
  PENDING
  PAYMENT_HELD
  DELIVERED
  RELEASED
  DISPUTED
  REFUNDED
  EXPIRED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_PROVIDER
  ESCALATED
  CLOSED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         Role     @default(BUYER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  buyerTransactions    Transaction[] @relation("BuyerTransactions")
  providerTransactions Transaction[] @relation("ProviderTransactions")
  disputesRaised       Dispute[]     @relation("DisputeRaisedBy")
  payouts              Payout[]
  auditLogs            AuditLog[]
  webhookEndpoints     WebhookEndpoint[]

  @@map("users")
}

model Transaction {
  id            String            @id @default(uuid())
  buyerId       String            @map("buyer_id")
  providerId    String            @map("provider_id")
  amount        Decimal           @db.Decimal(12, 2)
  currency      String            @default("USD") @db.VarChar(3)
  status        TransactionStatus @default(PENDING)
  description   String?
  platformFee   Decimal           @default(0) @map("platform_fee") @db.Decimal(12, 2)
  holdUntil     DateTime?         @map("hold_until")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  buyer    User @relation("BuyerTransactions", fields: [buyerId], references: [id])
  provider User @relation("ProviderTransactions", fields: [providerId], references: [id])

  disputes      Dispute[]
  payouts       Payout[]
  statusHistory TransactionStatusHistory[]
  milestones    Milestone[]

  @@map("transactions")
}

model Milestone {
  id            String   @id @default(uuid())
  transactionId String   @map("transaction_id")
  title         String
  description   String?
  amount        Decimal  @db.Decimal(12, 2)
  completed     Boolean  @default(false)
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@map("milestones")
}

model TransactionStatusHistory {
  id            String            @id @default(uuid())
  transactionId String            @map("transaction_id")
  fromStatus    TransactionStatus @map("from_status")
  toStatus      TransactionStatus @map("to_status")
  reason        String?
  changedBy     String?           @map("changed_by")
  createdAt     DateTime          @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@map("transaction_status_history")
}

model Dispute {
  id            String        @id @default(uuid())
  transactionId String        @map("transaction_id")
  raisedById    String        @map("raised_by_id")
  reason        String
  evidence      String?
  status        DisputeStatus @default(OPEN)
  resolution    String?
  resolvedAt    DateTime?     @map("resolved_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])
  raisedBy    User        @relation("DisputeRaisedBy", fields: [raisedById], references: [id])

  @@map("disputes")
}

model Payout {
  id            String       @id @default(uuid())
  providerId    String       @map("provider_id")
  transactionId String?      @map("transaction_id")
  amount        Decimal      @db.Decimal(12, 2)
  currency      String       @default("USD") @db.VarChar(3)
  status        PayoutStatus @default(PENDING)
  processedAt   DateTime?    @map("processed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  provider    User         @relation(fields: [providerId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@map("payouts")
}

model WebhookEndpoint {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  url       String
  secret    String
  active    Boolean  @default(true)
  events    String[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User           @relation(fields: [userId], references: [id])
  logs   WebhookEvent[]

  @@map("webhook_endpoints")
}

model WebhookEvent {
  id             String    @id @default(uuid())
  endpointId     String    @map("endpoint_id")
  eventType      String    @map("event_type")
  payload        Json
  idempotencyKey String    @unique @map("idempotency_key")
  processedAt    DateTime? @map("processed_at")
  attempts       Int       @default(0)
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@map("webhook_events")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
