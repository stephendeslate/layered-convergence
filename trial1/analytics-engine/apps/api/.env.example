# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/analytics_engine?schema=public"

# Redis
REDIS_URL="redis://localhost:6381"

# Auth
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# Encryption (32-byte hex key for AES-256-GCM)
ENCRYPTION_KEY="change-me-32-byte-hex-key-here!!"

# Bcrypt
BCRYPT_ROUNDS="12"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email (Resend)
SMTP_API_KEY=""

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:3002"

# App
PORT="3001"
NODE_ENV="development"
