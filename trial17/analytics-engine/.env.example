# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/analytics_engine?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — REQUIRED, no default fallback (FM #49)
JWT_SECRET=your-secure-jwt-secret-minimum-32-characters-long
JWT_EXPIRATION=3600s

# App
PORT=3000
NODE_ENV=development

# CORS — restricted origins (FM #50)
CORS_ORIGIN=http://localhost:3001
