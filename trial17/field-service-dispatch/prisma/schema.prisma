generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DISPATCHER
  TECHNICIAN
  VIEWER
}

enum WorkOrderStatus {
  CREATED
  ASSIGNED
  EN_ROUTE
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  INVOICED
  CLOSED
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TechnicianAvailability {
  AVAILABLE
  BUSY
  OFF_DUTY
  ON_LEAVE
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  technicians Technician[]
  customers   Customer[]
  workOrders  WorkOrder[]
  routes      Route[]
  invoices    Invoice[]
  gpsEvents   GpsEvent[]
}

model User {
  id        String   @id @default(cuid())
  email     String
  password  String
  name      String
  role      UserRole @default(VIEWER)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, companyId])
  @@index([companyId])
}

model Technician {
  id           String                 @id @default(cuid())
  email        String
  name         String
  phone        String?
  skills       String[]
  availability TechnicianAvailability @default(AVAILABLE)
  latitude     Float?
  longitude    Float?
  companyId    String
  company      Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  workOrders WorkOrder[]
  routes     Route[]
  gpsEvents  GpsEvent[]

  @@unique([email, companyId])
  @@index([companyId])
  @@index([availability])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String
  latitude  Float?
  longitude Float?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workOrders WorkOrder[]

  @@index([companyId])
}

model WorkOrder {
  id           String            @id @default(cuid())
  title        String
  description  String?
  status       WorkOrderStatus   @default(CREATED)
  priority     WorkOrderPriority @default(MEDIUM)
  scheduledAt  DateTime?
  completedAt  DateTime?
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  technicianId String?
  technician   Technician?       @relation(fields: [technicianId], references: [id])
  customerId   String?
  customer     Customer?         @relation(fields: [customerId], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  invoices Invoice[]

  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@index([technicianId])
}

model Route {
  id            String      @id @default(cuid())
  name          String
  date          DateTime
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  technicianId  String?
  technician    Technician? @relation(fields: [technicianId], references: [id])
  waypoints     Json?
  distance      Float?
  estimatedTime Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([companyId])
  @@index([date])
}

model Invoice {
  id          String   @id @default(cuid())
  number      String
  amount      Decimal  @db.Decimal(12, 2)
  tax         Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  notes       String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  issuedAt    DateTime @default(now())
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([workOrderId])
}

model GpsEvent {
  id           String     @id @default(cuid())
  latitude     Float
  longitude    Float
  accuracy     Float?
  heading      Float?
  speed        Float?
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  technicianId String
  technician   Technician @relation(fields: [technicianId], references: [id])
  recordedAt   DateTime   @default(now())
  createdAt    DateTime   @default(now())

  @@index([companyId])
  @@index([technicianId])
  @@index([recordedAt])
}
