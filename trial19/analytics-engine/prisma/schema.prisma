generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  VIEWER
  EDITOR
  ANALYST
  ADMIN
}

enum DataSourceStatus {
  ACTIVE
  INACTIVE
}

enum PipelineStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WidgetType {
  CHART
  TABLE
  METRIC
  MAP
}

enum SyncRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       User[]
  dataSources DataSource[]
  pipelines   Pipeline[]
  dashboards  Dashboard[]
  widgets     Widget[]
  embeds      Embed[]
  dataPoints  DataPoint[]
  syncRuns    SyncRun[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  tenantId  String   @map("tenant_id")
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

model DataSource {
  id               String           @id @default(uuid())
  tenantId         String           @map("tenant_id")
  name             String
  type             String
  connectionString String           @map("connection_string")
  status           DataSourceStatus @default(ACTIVE)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipelines  Pipeline[]
  dataPoints DataPoint[]
  syncRuns   SyncRun[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("data_sources")
}

model Pipeline {
  id           String         @id @default(uuid())
  tenantId     String         @map("tenant_id")
  name         String
  description  String?
  status       PipelineStatus @default(DRAFT)
  dataSourceId String         @map("data_source_id")
  config       Json           @default("{}")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dataSource DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("pipelines")
}

model DataPoint {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  dataSourceId String   @map("data_source_id")
  metric       String
  value        Decimal  @db.Decimal(20, 6)
  dimensions   Json     @default("{}")
  timestamp    DateTime
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dataSource DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, metric, timestamp])
  @@index([dataSourceId])
  @@map("data_points")
}

model Dashboard {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  layout      Json     @default("{}")
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  widgets Widget[]
  embeds  Embed[]

  @@index([tenantId])
  @@map("dashboards")
}

model Widget {
  id          String     @id @default(uuid())
  tenantId    String     @map("tenant_id")
  dashboardId String     @map("dashboard_id")
  type        WidgetType
  title       String
  config      Json       @default("{}")
  position    Json       @default("{}")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([dashboardId])
  @@map("widgets")
}

model Embed {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  dashboardId    String    @map("dashboard_id")
  token          String    @unique @default(uuid())
  expiresAt      DateTime? @map("expires_at")
  allowedOrigins String[]  @map("allowed_origins")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([token])
  @@map("embeds")
}

model SyncRun {
  id               String        @id @default(uuid())
  tenantId         String        @map("tenant_id")
  dataSourceId     String        @map("data_source_id")
  status           SyncRunStatus @default(PENDING)
  startedAt        DateTime      @default(now()) @map("started_at")
  completedAt      DateTime?     @map("completed_at")
  recordsProcessed Int           @default(0) @map("records_processed")
  errorMessage     String?       @map("error_message")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dataSource DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([dataSourceId])
  @@map("sync_runs")
}
