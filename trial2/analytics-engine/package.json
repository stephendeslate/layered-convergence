{
  "name": "analytics-engine",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:migrate": "pnpm --filter @analytics-engine/api exec prisma migrate dev",
    "db:generate": "pnpm --filter @analytics-engine/api exec prisma generate",
    "db:seed": "pnpm --filter @analytics-engine/api exec prisma db seed"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
