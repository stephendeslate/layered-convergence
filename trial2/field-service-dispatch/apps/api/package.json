    "@types/passport-jwt": "^4.0.0",
    "eslint": "^9.24.0",
    "prisma": "^6.6.0",
    "supertest": "^7.1.0",
    "@types/supertest": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.30.0",
    "unplugin-swc": "^1.5.0",
