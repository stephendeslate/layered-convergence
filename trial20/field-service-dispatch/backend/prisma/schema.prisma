generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DISPATCHER
  TECHNICIAN
}

enum TechnicianAvailability {
  AVAILABLE
  ON_JOB
  OFF_DUTY
}

enum WorkOrderStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  INVOICED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

model Company {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  customers   Customer[]
  technicians Technician[]
  workOrders  WorkOrder[]
  routes      Route[]
  gpsEvents   GpsEvent[]
  invoices    Invoice[]

  @@map("companies")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  companyId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id])
  technician Technician?

  @@map("users")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  address   String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]

  @@map("customers")
}

model Technician {
  id           String                 @id @default(uuid())
  userId       String                 @unique
  skills       String[]
  availability TechnicianAvailability @default(AVAILABLE)
  companyId    String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  company    Company     @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]
  routes     Route[]
  gpsEvents  GpsEvent[]

  @@map("technicians")
}

model WorkOrder {
  id           String          @id @default(uuid())
  title        String
  description  String
  status       WorkOrderStatus @default(PENDING)
  priority     Int             @default(3)
  customerId   String
  technicianId String?
  companyId    String
  scheduledAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  customer   Customer    @relation(fields: [customerId], references: [id])
  technician Technician? @relation(fields: [technicianId], references: [id])
  company    Company     @relation(fields: [companyId], references: [id])
  routes     Route[]
  invoices   Invoice[]

  @@map("work_orders")
}

model Route {
  id               String   @id @default(uuid())
  technicianId     String
  workOrderId      String
  distance         Float
  estimatedMinutes Int
  companyId        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  technician Technician @relation(fields: [technicianId], references: [id])
  workOrder  WorkOrder  @relation(fields: [workOrderId], references: [id])
  company    Company    @relation(fields: [companyId], references: [id])

  @@map("routes")
}

model GpsEvent {
  id           String   @id @default(uuid())
  technicianId String
  lat          Float
  lng          Float
  timestamp    DateTime @default(now())
  companyId    String
  createdAt    DateTime @default(now())

  technician Technician @relation(fields: [technicianId], references: [id])
  company    Company    @relation(fields: [companyId], references: [id])

  @@map("gps_events")
}

model Invoice {
  id          String        @id @default(uuid())
  workOrderId String
  amount      Decimal       @db.Decimal(12, 2)
  tax         Decimal       @db.Decimal(12, 2)
  total       Decimal       @db.Decimal(12, 2)
  status      InvoiceStatus @default(DRAFT)
  companyId   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])

  @@map("invoices")
}
