// [TRACED:DM-001] Prisma schema with PostgreSQL 16 provider
// [TRACED:SA-001] Prisma 6 ORM as data access layer

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// [TRACED:DM-002] Role enum restricted to VIEWER, EDITOR, ANALYST (no ADMIN)
enum Role {
  VIEWER
  EDITOR
  ANALYST
}

// [TRACED:DM-003] Pipeline state machine enum: DRAFT, ACTIVE, PAUSED, ARCHIVED
enum PipelineState {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WidgetType {
  BAR
  LINE
  PIE
  TABLE
  KPI
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

// [TRACED:DM-004] Tenant model as multi-tenancy root entity
model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       User[]
  dataSources DataSource[]
  dataPoints  DataPoint[]
  pipelines   Pipeline[]
  dashboards  Dashboard[]
  widgets     Widget[]
  embeds      Embed[]
  syncRuns    SyncRun[]

  @@map("tenants")
}

// [TRACED:DM-005] User model with tenant_id foreign key and @@map annotation
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(VIEWER)
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("users")
}

model DataSource {
  id        String   @id @default(uuid())
  name      String
  type      String
  config    Json     @default("{}")
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  dataPoints DataPoint[]
  syncRuns   SyncRun[]

  @@map("data_sources")
}

// [TRACED:DM-006] DataPoint.value uses Decimal(20,6) for precision
model DataPoint {
  id           String   @id @default(uuid())
  value        Decimal  @db.Decimal(20, 6)
  label        String
  timestamp    DateTime @default(now())
  tenantId     String   @map("tenant_id")
  dataSourceId String   @map("data_source_id")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  dataSource DataSource @relation(fields: [dataSourceId], references: [id])

  @@map("data_points")
}

model Pipeline {
  id        String        @id @default(uuid())
  name      String
  state     PipelineState @default(DRAFT)
  config    Json          @default("{}")
  tenantId  String        @map("tenant_id")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("pipelines")
}

model Dashboard {
  id        String   @id @default(uuid())
  name      String
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  widgets Widget[]

  @@map("dashboards")
}

model Widget {
  id          String     @id @default(uuid())
  title       String
  type        WidgetType
  config      Json       @default("{}")
  dashboardId String     @map("dashboard_id")
  tenantId    String     @map("tenant_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  dashboard Dashboard @relation(fields: [dashboardId], references: [id])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@map("widgets")
}

model Embed {
  id          String   @id @default(uuid())
  token       String   @unique @default(uuid())
  dashboardId String   @map("dashboard_id")
  tenantId    String   @map("tenant_id")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("embeds")
}

model SyncRun {
  id           String     @id @default(uuid())
  status       SyncStatus @default(PENDING)
  dataSourceId String     @map("data_source_id")
  tenantId     String     @map("tenant_id")
  startedAt    DateTime?  @map("started_at")
  completedAt  DateTime?  @map("completed_at")
  error        String?
  createdAt    DateTime   @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  dataSource DataSource @relation(fields: [dataSourceId], references: [id])

  @@map("sync_runs")
}
