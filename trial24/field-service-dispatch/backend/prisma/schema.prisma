// [TRACED:DM-001] All models use @@map for table names, @map for multi-word columns
// [TRACED:CQ-001] Zero `as any` type assertions in source code

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// [TRACED:SEC-001] User role enum restricts to DISPATCHER and TECHNICIAN only
enum Role {
  DISPATCHER
  TECHNICIAN
}

// [TRACED:DM-002] WorkOrder status enum includes all 7 states (OPEN, ASSIGNED, IN_PROGRESS, COMPLETED, INVOICED, CLOSED, CANCELLED)
enum WorkOrderStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  INVOICED
  CLOSED
  CANCELLED
}

// [TRACED:DM-003] Invoice status enum: DRAFT, SENT, PAID, VOID
enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

// [TRACED:DM-004] Route status enum: PLANNED, IN_PROGRESS, COMPLETED
enum RouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum GpsEventType {
  CHECK_IN
  CHECK_OUT
  EN_ROUTE
  IDLE
}

model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       User[]
  customers   Customer[]
  technicians Technician[]
  workOrders  WorkOrder[]
  routes      Route[]
  gpsEvents   GpsEvent[]
  invoices    Invoice[]

  @@map("companies")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role
  companyId    String   @map("company_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  technician Technician?

  @@map("users")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  companyId String   @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]
  invoices   Invoice[]

  @@map("customers")
}

model Technician {
  id             String   @id @default(uuid())
  name           String
  email          String
  phone          String?
  specialization String?
  companyId      String   @map("company_id")
  userId         String?  @unique @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])
  workOrders WorkOrder[]
  routes     Route[]
  gpsEvents  GpsEvent[]

  @@map("technicians")
}

model WorkOrder {
  id            String          @id @default(uuid())
  title         String
  description   String?
  status        WorkOrderStatus @default(OPEN)
  priority      String?
  scheduledDate DateTime?       @map("scheduled_date")
  completedDate DateTime?       @map("completed_date")
  customerId    String          @map("customer_id")
  technicianId  String?         @map("technician_id")
  companyId     String          @map("company_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  customer   Customer    @relation(fields: [customerId], references: [id])
  technician Technician? @relation(fields: [technicianId], references: [id])
  invoices   Invoice[]

  @@map("work_orders")
}

// [TRACED:DM-005] estimatedDistance uses Decimal(10,2), NOT Float
model Route {
  id                String      @id @default(uuid())
  name              String
  status            RouteStatus @default(PLANNED)
  date              DateTime
  estimatedDistance  Decimal     @db.Decimal(10, 2) @map("estimated_distance")
  technicianId      String      @map("technician_id")
  companyId         String      @map("company_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  technician Technician @relation(fields: [technicianId], references: [id])
  company    Company    @relation(fields: [companyId], references: [id])

  @@map("routes")
}

// [TRACED:DM-006] Float is used ONLY for GPS coordinates (latitude, longitude)
model GpsEvent {
  id           String       @id @default(uuid())
  latitude     Float
  longitude    Float
  timestamp    DateTime
  eventType    GpsEventType @default(CHECK_IN) @map("event_type")
  technicianId String       @map("technician_id")
  companyId    String       @map("company_id")

  technician Technician @relation(fields: [technicianId], references: [id])
  company    Company    @relation(fields: [companyId], references: [id])

  @@map("gps_events")
}

// [TRACED:DM-007] All monetary fields use Decimal(12,2)
model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @map("invoice_number")
  status        InvoiceStatus @default(DRAFT)
  amount        Decimal       @db.Decimal(12, 2)
  taxAmount     Decimal       @db.Decimal(12, 2) @map("tax_amount")
  totalAmount   Decimal       @db.Decimal(12, 2) @map("total_amount")
  dueDate       DateTime?     @map("due_date")
  workOrderId   String        @map("work_order_id")
  customerId    String        @map("customer_id")
  companyId     String        @map("company_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  customer  Customer  @relation(fields: [customerId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])

  @@unique([invoiceNumber, companyId])
  @@map("invoices")
}
