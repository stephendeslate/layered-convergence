// Analytics Engine — Prisma Schema
// 9 entities, 2 state machines (PipelineStatus, WidgetStatus)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  ANALYST
  VIEWER

  @@map("role")
}

enum PipelineStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED

  @@map("pipeline_status")
}

enum WidgetStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  ERROR

  @@map("widget_status")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users      User[]
  dashboards Dashboard[]
  dataSources DataSource[]
  pipelines  Pipeline[]

  @@map("tenants")
}

model User {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  email          String   @unique
  passwordHash   String   @map("password_hash")
  role           Role     @default(VIEWER)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  dashboards Dashboard[]
  widgets    Widget[]

  @@map("users")
}

model Dashboard {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  widgets Widget[]

  @@map("dashboards")
}

model Widget {
  id          String       @id @default(uuid())
  dashboardId String       @map("dashboard_id")
  userId      String       @map("user_id")
  name        String
  widgetType  String       @map("widget_type")
  config      Json         @default("{}")
  status      WidgetStatus @default(DRAFT)
  positionX   Int          @default(0) @map("position_x")
  positionY   Int          @default(0) @map("position_y")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  dashboard Dashboard @relation(fields: [dashboardId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("widgets")
}

model DataSource {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  name           String
  connectionType String   @map("connection_type")
  config         Json     @default("{}")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  pipelines Pipeline[]

  @@map("data_sources")
}

model Pipeline {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  dataSourceId String   @map("data_source_id")
  name         String
  schedule     String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  dataSource DataSource   @relation(fields: [dataSourceId], references: [id])
  runs       PipelineRun[]

  @@map("pipelines")
}

model PipelineRun {
  id          String         @id @default(uuid())
  pipelineId  String         @map("pipeline_id")
  status      PipelineStatus @default(PENDING)
  startedAt   DateTime       @default(now()) @map("started_at")
  completedAt DateTime?      @map("completed_at")
  errorMsg    String?        @map("error_msg")
  rowsRead    Int            @default(0) @map("rows_read")
  createdAt   DateTime       @default(now()) @map("created_at")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id])

  @@map("pipeline_runs")
}

model Report {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  query     String
  schedule  String?
  lastRunAt DateTime? @map("last_run_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("reports")
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  action    String
  entity    String
  entityId  String   @map("entity_id")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
