# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/analytics_engine?schema=public"

# Authentication
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="1h"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# API
API_PORT=3001
NODE_ENV="development"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
