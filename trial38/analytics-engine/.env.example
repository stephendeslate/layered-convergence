# Database connection (required)
# Connection pooling: adjust connection_limit based on expected concurrency
# For production, use PgBouncer or Prisma Data Proxy for advanced pooling
DATABASE_URL="postgresql://analytics:analytics@localhost:5432/analytics_engine?schema=public&connection_limit=10"

# JWT signing secret (required) — generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-secure-random-string"

# CORS allowed origin (required)
CORS_ORIGIN="http://localhost:3000"

# HTTP server port (optional, default: 3001)
PORT=3001

# Runtime environment (optional)
NODE_ENV=development

# API URL for the web frontend to reach the backend
API_URL="http://localhost:3001"
