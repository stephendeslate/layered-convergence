generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN  @map("admin")
  EDITOR @map("editor")
  VIEWER @map("viewer")

  @@map("user_role")
}

enum PipelineStatus {
  ACTIVE   @map("active")
  PAUSED   @map("paused")
  FAILED   @map("failed")
  ARCHIVED @map("archived")

  @@map("pipeline_status")
}

enum RunStatus {
  PENDING   @map("pending")
  RUNNING   @map("running")
  COMPLETED @map("completed")
  FAILED    @map("failed")

  @@map("run_status")
}

enum ReportFormat {
  PDF  @map("pdf")
  CSV  @map("csv")
  JSON @map("json")

  @@map("report_format")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users      User[]
  dashboards Dashboard[]
  pipelines  Pipeline[]
  reports    Report[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(VIEWER)
  tenantId     String   @map("tenant_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  dashboards Dashboard[]
  pipelines  Pipeline[]

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Dashboard {
  id          String   @id @default(cuid())
  title       String
  slug        String
  description String?
  config      Json?
  tenantId    String   @map("tenant_id")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  creator User     @relation(fields: [createdBy], references: [id])
  reports Report[]

  @@index([tenantId])
  @@map("dashboards")
}

model Pipeline {
  id          String         @id @default(cuid())
  name        String
  description String?
  schedule    String?
  status      PipelineStatus @default(ACTIVE)
  config      Json?
  tenantId    String         @map("tenant_id")
  createdBy   String         @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  tenant  Tenant        @relation(fields: [tenantId], references: [id])
  creator User          @relation(fields: [createdBy], references: [id])
  runs    PipelineRun[]

  @@index([tenantId])
  @@index([status])
  @@map("pipelines")
}

model PipelineRun {
  id           String    @id @default(cuid())
  pipelineId   String    @map("pipeline_id")
  status       RunStatus @default(PENDING)
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id])

  @@index([pipelineId])
  @@map("pipeline_runs")
}

model Report {
  id          String       @id @default(cuid())
  title       String
  description String?
  format      ReportFormat @default(PDF)
  data        Json?
  tenantId    String       @map("tenant_id")
  dashboardId String?      @map("dashboard_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  dashboard Dashboard? @relation(fields: [dashboardId], references: [id])

  @@index([tenantId])
  @@index([dashboardId])
  @@map("reports")
}
