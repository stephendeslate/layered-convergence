// Escrow Marketplace — Prisma Schema
// Two-sided marketplace with conditional payment release

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyerTransactions    Transaction[]        @relation("BuyerTransactions")
  providerTransactions Transaction[]        @relation("ProviderTransactions")
  stripeAccount        StripeConnectedAccount?
  payouts              Payout[]
  disputesRaised       Dispute[]

  @@index([role])
}

enum UserRole {
  BUYER
  PROVIDER
  ADMIN
}

model Transaction {
  id            String            @id @default(uuid())
  buyerId       String
  providerId    String
  amount        Int               // cents
  currency      String            @default("usd")
  status        TransactionStatus
  platformFee   Int               @default(0)
  holdUntil     DateTime?
  description   String?
  stripePaymentIntentId String?   @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  buyer         User              @relation("BuyerTransactions", fields: [buyerId], references: [id])
  provider      User              @relation("ProviderTransactions", fields: [providerId], references: [id])
  stateHistory  TransactionStateHistory[]
  dispute       Dispute?
  payout        Payout?

  @@index([buyerId])
  @@index([providerId])
  @@index([status])
}

enum TransactionStatus {
  PENDING
  HELD
  RELEASED
  DISPUTED
  REFUNDED
  EXPIRED
  COMPLETED
}

model TransactionStateHistory {
  id            String            @id @default(uuid())
  transactionId String
  fromState     TransactionStatus
  toState       TransactionStatus
  reason        String?
  createdAt     DateTime          @default(now())

  transaction   Transaction       @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
}

model Dispute {
  id            String          @id @default(uuid())
  transactionId String          @unique
  raisedById    String
  evidence      Json            @default("{}")
  resolution    DisputeResolution?
  resolvedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  transaction   Transaction     @relation(fields: [transactionId], references: [id])
  raisedBy      User            @relation(fields: [raisedById], references: [id])
}

enum DisputeResolution {
  BUYER_FAVOR
  PROVIDER_FAVOR
  ESCALATED
}

model StripeConnectedAccount {
  id                String   @id @default(uuid())
  userId            String   @unique
  stripeAccountId   String   @unique
  onboardingStatus  OnboardingStatus
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  RESTRICTED
}

model Payout {
  id                String       @id @default(uuid())
  providerId        String
  transactionId     String       @unique
  amount            Int          // cents
  stripeTransferId  String?      @unique
  status            PayoutStatus
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  provider          User         @relation(fields: [providerId], references: [id])
  transaction       Transaction  @relation(fields: [transactionId], references: [id])

  @@index([providerId])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model WebhookLog {
  id              String    @id @default(uuid())
  provider        String    @default("stripe")
  eventType       String
  payload         Json
  idempotencyKey  String    @unique
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([idempotencyKey])
  @@index([eventType])
}
