generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN  @map("admin")
  EDITOR @map("editor")
  VIEWER @map("viewer")

  @@map("user_role")
}

enum EventType {
  PAGE_VIEW  @map("page_view")
  CLICK      @map("click")
  CONVERSION @map("conversion")
  CUSTOM     @map("custom")

  @@map("event_type")
}

enum PipelineStatus {
  IDLE      @map("idle")
  RUNNING   @map("running")
  COMPLETED @map("completed")
  FAILED    @map("failed")

  @@map("pipeline_status")
}

enum DataSourceType {
  DATABASE @map("database")
  API      @map("api")
  FILE     @map("file")
  STREAM   @map("stream")

  @@map("data_source_type")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       User[]
  events      Event[]
  dashboards  Dashboard[]
  dataSources DataSource[]
  pipelines   Pipeline[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(VIEWER)
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  dashboards Dashboard[]

  @@index([tenantId])
  @@index([role])
  @@map("users")
}

model Event {
  id        String    @id @default(uuid())
  type      EventType
  name      String
  payload   Json      @default("{}")
  tenantId  String    @map("tenant_id")
  createdAt DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@index([tenantId, type])
  @@map("events")
}

model Dashboard {
  id          String   @id @default(uuid())
  title       String
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  tenantId    String   @map("tenant_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, isPublic])
  @@map("dashboards")
}

model DataSource {
  id        String         @id @default(uuid())
  name      String
  type      DataSourceType
  config    Json           @default("{}")
  cost      Decimal        @db.Decimal(12, 2) @default(0)
  tenantId  String         @map("tenant_id")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  pipelines Pipeline[]

  @@index([tenantId])
  @@index([type])
  @@map("data_sources")
}

model Pipeline {
  id           String         @id @default(uuid())
  name         String
  description  String?
  status       PipelineStatus @default(IDLE)
  schedule     String?
  tenantId     String         @map("tenant_id")
  dataSourceId String         @map("data_source_id")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  dataSource DataSource @relation(fields: [dataSourceId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@map("pipelines")
}
