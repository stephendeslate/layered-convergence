generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN    @map("admin")
  USER     @map("user")
  VIEWER   @map("viewer")
  EDITOR   @map("editor")

  @@map("user_role")
}

enum EventType {
  CLICK       @map("click")
  PAGE_VIEW   @map("page_view")
  API_CALL    @map("api_call")
  CUSTOM      @map("custom")
  ERROR       @map("error")

  @@map("event_type")
}

enum EventStatus {
  PENDING    @map("pending")
  PROCESSED  @map("processed")
  FAILED     @map("failed")
  ARCHIVED   @map("archived")

  @@map("event_status")
}

enum PipelineStatus {
  ACTIVE    @map("active")
  PAUSED    @map("paused")
  FAILED    @map("failed")
  DISABLED  @map("disabled")

  @@map("pipeline_status")
}

enum DataSourceType {
  POSTGRESQL  @map("postgresql")
  MYSQL       @map("mysql")
  REST_API    @map("rest_api")
  CSV         @map("csv")
  S3          @map("s3")

  @@map("data_source_type")
}

enum DataSourceStatus {
  CONNECTED     @map("connected")
  DISCONNECTED  @map("disconnected")
  ERROR         @map("error")

  @@map("data_source_status")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       User[]
  events      Event[]
  dashboards  Dashboard[]
  dataSources DataSource[]
  pipelines   Pipeline[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(USER)
  tenantId     String   @map("tenant_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  dashboards Dashboard[]

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Event {
  id        String      @id @default(uuid())
  type      EventType
  status    EventStatus @default(PENDING)
  payload   Json        @default("{}")
  source    String      @db.VarChar(255)
  tenantId  String      @map("tenant_id")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([type])
  @@map("events")
}

model Dashboard {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  config      Json     @default("{}")
  isPublic    Boolean  @default(false) @map("is_public")
  tenantId    String   @map("tenant_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, userId])
  @@map("dashboards")
}

model DataSource {
  id             String           @id @default(uuid())
  name           String           @db.VarChar(255)
  type           DataSourceType
  status         DataSourceStatus @default(DISCONNECTED)
  connectionUri  String           @map("connection_uri") @db.VarChar(500)
  config         Json             @default("{}")
  monthlyCost    Decimal          @map("monthly_cost") @db.Decimal(12, 2)
  tenantId       String           @map("tenant_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  pipelines Pipeline[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@map("data_sources")
}

model Pipeline {
  id            String         @id @default(uuid())
  name          String         @db.VarChar(255)
  description   String?        @db.Text
  status        PipelineStatus @default(ACTIVE)
  schedule      String?        @db.VarChar(100)
  config        Json           @default("{}")
  processingCost Decimal       @map("processing_cost") @db.Decimal(12, 2)
  dataSourceId  String         @map("data_source_id")
  tenantId      String         @map("tenant_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  dataSource DataSource @relation(fields: [dataSourceId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([dataSourceId])
  @@index([tenantId, status])
  @@map("pipelines")
}
