generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id           String   @id @default(uuid())
  name         String
  primaryColor String   @default("#3B82F6")
  logoUrl      String?
  serviceArea  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  technicians  Technician[]
  customers    Customer[]
  workOrders   WorkOrder[]
}

model Technician {
  id         String           @id @default(uuid())
  companyId  String
  name       String
  email      String
  phone      String?
  skills     String[]         @default([])
  status     TechnicianStatus @default(AVAILABLE)
  currentLat Float?
  currentLng Float?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  company    Company          @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]
  routes     Route[]

  @@index([companyId])
  @@index([status])
}

enum TechnicianStatus {
  AVAILABLE
  BUSY
  OFF_DUTY
}

model Customer {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String
  phone     String?
  address   String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id])
  workOrders WorkOrder[]

  @@index([companyId])
}

model WorkOrder {
  id           String          @id @default(uuid())
  companyId    String
  customerId   String
  technicianId String?
  title        String
  description  String?
  priority     WorkOrderPriority @default(MEDIUM)
  status       WorkOrderStatus   @default(UNASSIGNED)
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  trackingToken String?         @unique
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  company      Company          @relation(fields: [companyId], references: [id])
  customer     Customer         @relation(fields: [customerId], references: [id])
  technician   Technician?      @relation(fields: [technicianId], references: [id])
  statusHistory WorkOrderStatusHistory[]
  photos       JobPhoto[]
  invoice      Invoice?

  @@index([companyId])
  @@index([technicianId])
  @@index([status])
  @@index([trackingToken])
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkOrderStatus {
  UNASSIGNED
  ASSIGNED
  EN_ROUTE
  ON_SITE
  IN_PROGRESS
  COMPLETED
  INVOICED
  PAID
}

model WorkOrderStatusHistory {
  id          String          @id @default(uuid())
  workOrderId String
  fromStatus  WorkOrderStatus
  toStatus    WorkOrderStatus
  note        String?
  createdAt   DateTime        @default(now())

  workOrder   WorkOrder       @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
}

model Route {
  id               String   @id @default(uuid())
  technicianId     String
  date             DateTime @db.Date
  waypoints        Json
  optimizedOrder   Int[]    @default([])
  estimatedDuration Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  technician       Technician @relation(fields: [technicianId], references: [id])

  @@index([technicianId, date])
}

model JobPhoto {
  id          String   @id @default(uuid())
  workOrderId String
  url         String
  caption     String?
  uploadedAt  DateTime @default(now())

  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
}

model Invoice {
  id                    String        @id @default(uuid())
  workOrderId           String        @unique
  amount                Int
  status                InvoiceStatus @default(DRAFT)
  stripePaymentIntentId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  workOrder             WorkOrder     @relation(fields: [workOrderId], references: [id])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Notification {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([companyId])
}
