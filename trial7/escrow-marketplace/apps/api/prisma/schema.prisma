generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyerTransactions    Transaction[] @relation("BuyerTransactions")
  providerTransactions Transaction[] @relation("ProviderTransactions")
  raisedDisputes       Dispute[]     @relation("RaisedDisputes")
  connectedAccount     StripeConnectedAccount?
  payouts              Payout[]

  @@map("users")
}

enum UserRole {
  BUYER
  PROVIDER
  ADMIN
}

model Transaction {
  id              String            @id @default(cuid())
  buyerId         String
  providerId      String
  amount          Int
  currency        String            @default("usd")
  status          TransactionStatus @default(PENDING)
  platformFee     Int               @default(0)
  holdUntil       DateTime?
  stripePaymentId String?           @unique
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  buyer           User              @relation("BuyerTransactions", fields: [buyerId], references: [id])
  provider        User              @relation("ProviderTransactions", fields: [providerId], references: [id])
  stateHistory    TransactionStateHistory[]
  disputes        Dispute[]
  payout          Payout?

  @@map("transactions")
}

enum TransactionStatus {
  PENDING
  HELD
  RELEASED
  DISPUTED
  REFUNDED
  EXPIRED
  COMPLETED
}

model TransactionStateHistory {
  id            String   @id @default(cuid())
  transactionId String
  fromState     String
  toState       String
  reason        String?
  timestamp     DateTime @default(now())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("transaction_state_history")
}

model Dispute {
  id            String          @id @default(cuid())
  transactionId String
  raisedById    String
  reason        String
  evidence      Json            @default("[]")
  resolution    DisputeResolution?
  resolvedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  raisedBy      User        @relation("RaisedDisputes", fields: [raisedById], references: [id])

  @@map("disputes")
}

enum DisputeResolution {
  BUYER_FAVOR
  PROVIDER_FAVOR
  SPLIT
  ESCALATED
}

model StripeConnectedAccount {
  id               String                    @id @default(cuid())
  userId           String                    @unique
  stripeAccountId  String                    @unique
  onboardingStatus ConnectedAccountStatus    @default(PENDING)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("stripe_connected_accounts")
}

enum ConnectedAccountStatus {
  PENDING
  ONBOARDING
  ACTIVE
  RESTRICTED
}

model Payout {
  id               String       @id @default(cuid())
  userId           String
  transactionId    String       @unique
  amount           Int
  stripeTransferId String?      @unique
  status           PayoutStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user             User        @relation(fields: [userId], references: [id])
  transaction      Transaction @relation(fields: [transactionId], references: [id])

  @@map("payouts")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model WebhookLog {
  id              String    @id @default(cuid())
  provider        String    @default("stripe")
  eventType       String
  payload         Json
  idempotencyKey  String    @unique
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@map("webhook_logs")
}
