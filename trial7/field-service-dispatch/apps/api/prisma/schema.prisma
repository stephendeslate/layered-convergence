generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  branding    Json     @default("{}")
  serviceArea Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  technicians Technician[]
  customers   Customer[]
  workOrders  WorkOrder[]

  @@map("companies")
}

model Technician {
  id         String          @id @default(cuid())
  companyId  String
  name       String
  email      String          @unique
  phone      String?
  skills     Json            @default("[]")
  currentLat Float?
  currentLng Float?
  status     TechnicianStatus @default(AVAILABLE)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]
  routes     Route[]

  @@map("technicians")
}

enum TechnicianStatus {
  AVAILABLE
  BUSY
  OFF_DUTY
}

model Customer {
  id        String   @id @default(cuid())
  companyId String
  name      String
  address   String
  lat       Float
  lng       Float
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@map("customers")
}

model WorkOrder {
  id           String          @id @default(cuid())
  companyId    String
  customerId   String
  technicianId String?
  title        String
  description  String?
  priority     WorkOrderPriority @default(MEDIUM)
  status       WorkOrderStatus   @default(UNASSIGNED)
  scheduledAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer     Customer   @relation(fields: [customerId], references: [id])
  technician   Technician? @relation(fields: [technicianId], references: [id])
  statusHistory WorkOrderStatusHistory[]
  photos       JobPhoto[]
  invoice      Invoice?

  @@map("work_orders")
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkOrderStatus {
  UNASSIGNED
  ASSIGNED
  EN_ROUTE
  ON_SITE
  IN_PROGRESS
  COMPLETED
  INVOICED
  PAID
}

model WorkOrderStatusHistory {
  id          String   @id @default(cuid())
  workOrderId String
  fromStatus  String
  toStatus    String
  note        String?
  timestamp   DateTime @default(now())

  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("work_order_status_history")
}

model Route {
  id                String   @id @default(cuid())
  technicianId      String
  date              DateTime @db.Date
  waypoints         Json     @default("[]")
  optimizedOrder    Json     @default("[]")
  estimatedDuration Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  technician        Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@unique([technicianId, date])
  @@map("routes")
}

model JobPhoto {
  id          String   @id @default(cuid())
  workOrderId String
  url         String
  caption     String?
  uploadedAt  DateTime @default(now())

  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("job_photos")
}

model Invoice {
  id                    String        @id @default(cuid())
  workOrderId           String        @unique
  amount                Int
  status                InvoiceStatus @default(DRAFT)
  stripePaymentIntentId String?       @unique
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  workOrder             WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}
